# ── MT5 File Bridge ──────────────────────────────
MT5_SESSION_PREFIX=signal
# MT5 Common Files path — auto-detected on Windows, override if needed
# MT5_FILES_PATH=C:\Users\...\AppData\Roaming\MetaQuotes\Terminal\Common\Files

# ── AI Provider ──────────────────────────────────
AI_PROVIDER=claude         # claude | openai | deepseek | gemini | ollama
AI_API_KEY=                # paste your Claude API key here
AI_MODEL=claude-haiku-4-5  # cheapest current Claude model, ~$0.20/month at this volume
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=phi3          # fallback only — not recommended as primary

# ── Telegram (channel listener) ──────────────────
TELEGRAM_API_ID=...
TELEGRAM_API_HASH=...
TELEGRAM_SESSION_NAME=signal_session

# ── Telegram (bot notifications) ─────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Dashboard ────────────────────────────────────
DASHBOARD_PORT=8501