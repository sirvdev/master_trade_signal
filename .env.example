# ── MT5 File Bridge ──────────────────────────────
MT5_SESSION_PREFIX=signal
# MT5 Common Files path — auto-detected on Windows, override if needed
# MT5_FILES_PATH=C:\Users\...\AppData\Roaming\MetaQuotes\Terminal\Common\Files

# ── AI Provider ──────────────────────────────────
AI_PROVIDER=claude          # claude | openai | deepseek | ollama
AI_API_KEY=sk-...
AI_MODEL=                   # optional, uses sensible default per provider

# ── Telegram (channel listener) ──────────────────
TELEGRAM_API_ID=...
TELEGRAM_API_HASH=...
TELEGRAM_SESSION_NAME=signal_session

# ── Telegram (bot notifications) ─────────────────
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# ── Dashboard ────────────────────────────────────
DASHBOARD_PORT=8501